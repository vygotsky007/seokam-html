# Supabase 연결 (실제 값은 .env 에 넣고, .env 는 커밋하지 말 것)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
PORT=4002

# 비전 AI 변환 (이미지 폴백 문항 → 구조화 텍스트). 키는 코드·레포에 절대 넣지 말 것.
# 발급: https://console.anthropic.com/ → API Keys → Create Key (sk-ant-... 로 시작)
ANTHROPIC_API_KEY=
AI_DAILY_LIMIT=200          # 하루 AI 변환 호출 상한(비용 안전장치)
# TEACHER_TOKEN=            # 설정 시 /api/ai-convert 에 x-teacher-token 헤더 일치 요구(선택)
